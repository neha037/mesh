# ── Stage 1: Build ────────────────────────────────────────
FROM golang:1.24-alpine AS builder

WORKDIR /app

COPY go.mod go.sum* ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /mesh-worker ./cmd/worker

# ── Stage 2: Run ─────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /mesh-worker /mesh-worker

ENTRYPOINT ["/mesh-worker"]
